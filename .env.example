# SunSponge environment variables
#
# Copy to `.env` and fill in real values. NEVER commit `.env` to git.
# `.gitignore` already excludes it.

# Bearer token for the RHOBEAR Vertex Gateway (https://gw.rhobear.ai/v1).
# The AI pipeline (src/sunsponge/demo_ai.py) reads this on every LLM call
# and fails loud if it's missing. Get a token from the gateway admin and
# rotate it if you suspect it has been exposed.
RHOBEAR_GW_API_KEY=

# Optional: override the gateway base URL.
# Default: https://gw.rhobear.ai/v1
# RHOBEAR_GW_BASE_URL=
